# Base URL of the Laravel API. Server-only (NOT prefixed with NEXT_PUBLIC_),
# so it is never exposed to the browser. Include the `/api` segment if your
# Laravel routes live there. No trailing slash needed.
LARAVEL_API_URL=http://localhost:8000/api

# Public Laravel API base URL reachable from the BROWSER (same value in dev).
# Used for direct document uploads (browser -> API) to bypass Vercel's 4.5MB
# serverless body limit. The upload route needs CORS for the frontend origin.
NEXT_PUBLIC_LARAVEL_API_URL=http://localhost:8000/api

# Set to "true" to enable the admin-only runtime brand-color editor
# (Settings -> Branding, for admin@doxie.ai). When unset/false the feature and
# its inline init script are not rendered at all. Optional.
ALLOW_RUNTIME_BRANDING=false

# Pusher (Laravel Echo) credentials — client-exposed, for realtime document status.
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=mt1
